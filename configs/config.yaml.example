paths:
  store_root: "./var"
  runs_root: "./var/runs"
  symbol_master_csv: "${TRADINGLAB_STORE:-../tradinglab-store}/meta/symbol_master.csv"
  exchange_defaults_csv: "${TRADINGLAB_STORE:-../tradinglab-store}/meta/exchange_defaults.csv"
  symbol_overrides_csv: "${TRADINGLAB_STORE:-../tradinglab-store}/meta/symbol_overrides.csv"
  fx_daily_root: "${TRADINGLAB_STORE:-../tradinglab-store}/parquet/fx_daily"

timeframe: "1d"
lookback_days: 2000

yf:
  chunk_size: 100
  sleep_seconds: 2.0
  max_retries: 5
  backoff_max_seconds: 120.0
  threads: false

update:
  history_provider: "yfinance"
  recent_provider: "yfinance"
  recent_days: 5
  incremental_days: 60
  assert_postwrite_integrity: true
  stooq_refresh_all: false

extended_hours:
  enabled: true
  preferred_interval: "5m"
  fallback_interval: "1m"
  retention_days: 0
  prepost: true
  chunk_size: 20
  sleep_seconds: 1.0
  max_retries: 5
  backoff_max_seconds: 120.0
  threads: false
  log_repeat_cooldown_hours: 24.0
  pct_move_threshold: 2.0
  min_volume: 0

intraday:
  enabled: true
  interval: "5m"
  provider: "yahoo"
  session: "regular"
  exchange_timezone: "America/New_York"
  default_universe: "intraday_pilot"
  retention_days: 0
  chunk_size: 20
  sleep_seconds: 1.0
  max_retries: 5
  backoff_max_seconds: 120.0
  threads: false
  log_repeat_cooldown_hours: 24.0

intraday_live:
  enabled: true
  interval: "5m"
  provider: "yahoo"
  exchange_timezone: "America/New_York"
  default_universe: "intraday_live_core"
  retention_days: 0
  chunk_size: 20
  sleep_seconds: 1.0
  max_retries: 5
  backoff_max_seconds: 120.0
  threads: false
  log_repeat_cooldown_hours: 24.0

crypto:
  provider: "binance"
  exchange: "binance"
  market_type: "spot"
  default_universe: "crypto_majors"
  quote_assets:
    - "USDT"
  max_batch_limit: 1000
  incremental_lookback_bars: 500
  full_backfill_limit: 5000
  validate_continuity: true
  universe_refresh_provider: "coingecko"
  universe_refresh_limit: 25
  universe_refresh_pages: 2
  universe_refresh_min_market_cap: 0
  universe_refresh_min_volume: 0
  stablecoin_ids:
    - "tether"
    - "usd-coin"
    - "dai"
  excluded_symbols: []
  excluded_ids: []
  exclude_wrapped_assets: true
